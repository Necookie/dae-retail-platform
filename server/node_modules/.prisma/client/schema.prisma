// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum ProductionStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum TransactionType {
  PURCHASE
  SALE
  ADJUSTMENT
  RESERVATION
  CANCELLATION
}

enum ReservationStatus {
  RESERVED
  DEDUCTED
  RELEASED
}

enum CostingMethod {
  WEIGHTED_AVERAGE
  LATEST_PURCHASE
  MANUAL_OVERRIDE
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sales Sales[]

  @@map("users")
}

model RawMaterial {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?
  unit      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variants         MaterialVariant[]
  productMaterials ProductMaterial[]

  @@map("raw_materials")
}

model MaterialVariant {
  id              Int         @id @default(autoincrement())
  materialId      Int         @map("material_id")
  material        RawMaterial @relation(fields: [materialId], references: [id])
  name            String
  sku             String?
  quantityOnHand  Decimal     @default(0) @map("quantity_on_hand") @db.Decimal(12, 4)
  reorderLevel    Decimal     @default(0) @map("reorder_level") @db.Decimal(12, 4)
  manualUnitCost  Decimal?    @map("manual_unit_cost") @db.Decimal(12, 4)
  weightedAvgCost Decimal     @default(0) @map("weighted_avg_cost") @db.Decimal(12, 4)
  latestUnitCost  Decimal     @default(0) @map("latest_unit_cost") @db.Decimal(12, 4)
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  purchases             Purchase[]
  productMaterials      ProductMaterial[]
  saleMaterialSnapshots SaleMaterialSnapshot[]
  inventoryReservations InventoryReservation[]

  @@map("material_variants")
}

model Purchase {
  id           Int             @id @default(autoincrement())
  variantId    Int             @map("variant_id")
  variant      MaterialVariant @relation(fields: [variantId], references: [id])
  supplier     String?
  quantity     Decimal         @db.Decimal(12, 4)
  unitCost     Decimal         @map("unit_cost") @db.Decimal(12, 4)
  totalCost    Decimal         @map("total_cost") @db.Decimal(12, 4)
  purchaseDate DateTime        @default(now()) @map("purchase_date")
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([purchaseDate])
  @@map("purchases")
}

model Product {
  id               Int              @id @default(autoincrement())
  name             String
  sku              String?          @unique
  description      String?
  sellingPrice     Decimal          @map("selling_price") @db.Decimal(12, 4)
  productionStatus ProductionStatus @default(PENDING) @map("production_status")
  paymentStatus    PaymentStatus    @default(UNPAID) @map("payment_status")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  productMaterials      ProductMaterial[]
  sales                 Sales[]
  inventoryReservations InventoryReservation[]

  @@map("products")
}

model ProductMaterial {
  productId        Int             @map("product_id")
  materialId       Int             @map("material_id") // Keep this to quickly filter by base type (Optional, but keeping to avoid too many cascading changes)
  variantId        Int             @map("variant_id")
  product          Product         @relation(fields: [productId], references: [id])
  material         RawMaterial     @relation(fields: [materialId], references: [id])
  variant          MaterialVariant @relation(fields: [variantId], references: [id])
  quantityRequired Decimal         @map("quantity_required") @db.Decimal(12, 4)

  @@id([productId, variantId])
  @@map("product_materials")
}

model Sales {
  id                     Int           @id @default(autoincrement())
  productId              Int           @map("product_id")
  product                Product       @relation(fields: [productId], references: [id])
  soldById               Int?          @map("sold_by_id")
  soldBy                 User?         @relation(fields: [soldById], references: [id])
  quantity               Int           @default(1)
  unitPrice              Decimal       @map("unit_price") @db.Decimal(12, 4)
  totalRevenue           Decimal       @map("total_revenue") @db.Decimal(12, 4)
  productionCostSnapshot Decimal       @map("production_cost_snapshot") @db.Decimal(12, 4)
  profit                 Decimal       @db.Decimal(12, 4)
  paymentStatus          PaymentStatus @default(UNPAID) @map("payment_status")
  notes                  String?
  saleDate               DateTime      @default(now()) @map("sale_date")
  createdAt              DateTime      @default(now()) @map("created_at")

  materialSnapshots SaleMaterialSnapshot[]

  @@index([saleDate])
  @@map("sales")
}

model SaleMaterialSnapshot {
  id               Int             @id @default(autoincrement())
  saleId           Int             @map("sale_id")
  sale             Sales           @relation(fields: [saleId], references: [id])
  variantId        Int             @map("variant_id")
  variant          MaterialVariant @relation(fields: [variantId], references: [id])
  unitCostSnapshot Decimal         @map("unit_cost_snapshot") @db.Decimal(12, 4)
  quantityUsed     Decimal         @map("quantity_used") @db.Decimal(12, 4)

  @@map("sale_material_snapshots")
}

model Transaction {
  id          Int             @id @default(autoincrement())
  type        TransactionType
  referenceId Int?            @map("reference_id")
  amount      Decimal         @db.Decimal(12, 4)
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("transactions")
}

model InventoryReservation {
  id          Int               @id @default(autoincrement())
  productId   Int               @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  variantId   Int               @map("variant_id")
  variant     MaterialVariant   @relation(fields: [variantId], references: [id])
  reservedQty Decimal           @map("reserved_qty") @db.Decimal(12, 4)
  status      ReservationStatus @default(RESERVED)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("inventory_reservations")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
